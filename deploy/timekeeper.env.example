# App settings loaded by deploy/timekeeper.service. Copy to deploy/timekeeper.env
# and fill in. This file is git-ignored (it holds secrets), so it is NOT in
# backups — keep the PIN/secret somewhere safe (e.g. a password manager).

# Admin PIN for the /admin page.
TIMEKEEPER_PIN=1234

# Flask session secret — set to a long random string (e.g. `openssl rand -hex 32`).
TIMEKEEPER_SECRET=change-me-to-a-long-random-string

# Optional tuning (defaults shown; uncomment to change):
# TIMEKEEPER_EARLY_GRACE_MIN=15   # minutes before a shift start a worker may clock in
# TIMEKEEPER_OVERTIME_MIN=60      # minutes past end before a forgotten entry auto-closes
# TIMEKEEPER_MISSED_MIN=30        # minutes after start with no clock-in before an alert
