[Unit]
Description=TimeKeeper time clock web app
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ayi102
WorkingDirectory=/home/ayi102/TimeKeeper
Environment=PORT=80
EnvironmentFile=/home/ayi102/TimeKeeper/deploy/timekeeper.env
ExecStart=/home/ayi102/TimeKeeper/.venv/bin/python app.py
AmbientCapabilities=CAP_NET_BIND_SERVICE
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
