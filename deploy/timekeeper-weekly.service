[Unit]
Description=TimeKeeper weekly hours email
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=ayi102
WorkingDirectory=/home/ayi102/TimeKeeper
EnvironmentFile=/home/ayi102/TimeKeeper/deploy/mail.env
ExecStart=/home/ayi102/TimeKeeper/.venv/bin/python weekly_email.py --this-week
